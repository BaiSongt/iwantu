# ============================================
# iWantU Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://iwantu:iwantu123@localhost:5432/iwantu

# JWT secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=dev-secret-change-in-production

# SMTP mail server (used for email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Node environment: development | production | test
NODE_ENV=development

# Directory for uploaded files
UPLOAD_DIR=/data/uploads
